{
  "name": "fumadocs-vscode-plugin",
  "displayName": "Fumadocs Preview",
  "description": "Live-preview any MDX/Markdown file or folder with a real Fumadocs site, rendered side-by-side inside VSCode.",
  "version": "1.1.0",
  "publisher": "researchanddesire",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/researchanddesire/fumadocs-vscode-plugin.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "fumadocs",
    "mdx",
    "markdown",
    "docs",
    "preview"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onView:fumadocs.docsTools",
    "onLanguage:mdx",
    "onLanguage:markdown"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fumadocs.openPreview",
        "title": "Preview",
        "shortTitle": "Preview",
        "category": "Fumadocs",
        "icon": "$(book)"
      },
      {
        "command": "fumadocs.openInBrowser",
        "title": "Open in Browser",
        "shortTitle": "Browser",
        "category": "Fumadocs",
        "icon": "$(link-external)"
      },
      {
        "command": "fumadocs.refreshPreview",
        "title": "Refresh Preview",
        "shortTitle": "Refresh",
        "category": "Fumadocs",
        "icon": "$(refresh)"
      },
      {
        "command": "fumadocs.docsTools.addImage",
        "title": "Add Image",
        "category": "Fumadocs",
        "icon": "$(file-media)"
      },
      {
        "command": "fumadocs.editImage",
        "title": "Edit Image",
        "category": "Fumadocs",
        "icon": "$(device-camera)"
      },
      {
        "command": "fumadocs.docsTools.addComponent",
        "title": "Add Component",
        "category": "Fumadocs",
        "icon": "$(symbol-snippet)"
      },
      {
        "command": "fumadocs.insertComponent.accordions",
        "title": "Accordions",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.banner",
        "title": "Banner",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.callout",
        "title": "Callout",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.cards",
        "title": "Cards",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.code-block-tabs",
        "title": "CodeBlockTabs",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.codeblock",
        "title": "Code block",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.table",
        "title": "Table",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.files",
        "title": "Files",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.inline-toc",
        "title": "InlineTOC",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.steps",
        "title": "Steps",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.tabs",
        "title": "Tabs",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.insertComponent.type-table",
        "title": "TypeTable",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.docsTools.refresh",
        "title": "Refresh Docs Tools",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.editMeta",
        "title": "Edit meta.json",
        "category": "Fumadocs",
        "icon": "$(edit)"
      },
      {
        "command": "fumadocs.syncMeta",
        "title": "Sync meta.json (include missing pages)",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.meta.addPages",
        "title": "Add pages to meta.json",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.meta.addRest",
        "title": "Add rest (...) to meta.json",
        "category": "Fumadocs"
      },
      {
        "command": "fumadocs.meta.removeRefs",
        "title": "Remove entries from meta.json",
        "category": "Fumadocs"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fumadocs",
          "title": "Fumadocs",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "fumadocs": [
        {
          "type": "webview",
          "id": "fumadocs.docsTools",
          "name": "Docs Tools"
        }
      ]
    },
    "submenus": [
      {
        "id": "fumadocs.editorMenu",
        "label": "Fumadocs"
      },
      {
        "id": "fumadocs.contextMenu",
        "label": "Fumadocs Preview",
        "icon": "$(book)"
      },
      {
        "id": "fumadocs.insertComponentMenu",
        "label": "Insert Component",
        "icon": "$(symbol-snippet)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "fumadocs.editMeta",
          "when": "explorerResourceIsFolder",
          "group": "fumadocs@1"
        }
      ],
      "editor/title": [
        {
          "submenu": "fumadocs.editorMenu",
          "when": "editorLangId == mdx || editorLangId == markdown || resourceExtname == .md || resourceExtname == .mdx",
          "group": "navigation@0"
        },
        {
          "command": "fumadocs.editMeta",
          "when": "resourceFilename == meta.json || resourceFilename == meta.jsonc",
          "group": "navigation@0"
        }
      ],
      "fumadocs.editorMenu": [
        {
          "command": "fumadocs.openPreview",
          "group": "1_main@1"
        },
        {
          "command": "fumadocs.openInBrowser",
          "when": "fumadocs.previewActive",
          "group": "1_main@2"
        }
      ],
      "editor/context": [
        {
          "submenu": "fumadocs.contextMenu",
          "when": "editorLangId == mdx || editorLangId == markdown || resourceExtname == .md || resourceExtname == .mdx",
          "group": "navigation@0"
        }
      ],
      "fumadocs.contextMenu": [
        {
          "command": "fumadocs.openPreview",
          "group": "1_preview@1"
        },
        {
          "command": "fumadocs.docsTools.addImage",
          "when": "fumadocs.docsToolsEnabled",
          "group": "2_insert@1"
        },
        {
          "submenu": "fumadocs.insertComponentMenu",
          "when": "fumadocs.docsToolsEnabled",
          "group": "2_insert@2"
        }
      ],
      "fumadocs.insertComponentMenu": [
        {
          "command": "fumadocs.insertComponent.accordions",
          "group": "components@1"
        },
        {
          "command": "fumadocs.insertComponent.banner",
          "group": "components@2"
        },
        {
          "command": "fumadocs.insertComponent.callout",
          "group": "components@3"
        },
        {
          "command": "fumadocs.insertComponent.cards",
          "group": "components@4"
        },
        {
          "command": "fumadocs.insertComponent.code-block-tabs",
          "group": "components@5"
        },
        {
          "command": "fumadocs.insertComponent.files",
          "group": "components@6"
        },
        {
          "command": "fumadocs.insertComponent.inline-toc",
          "group": "components@7"
        },
        {
          "command": "fumadocs.insertComponent.steps",
          "group": "components@8"
        },
        {
          "command": "fumadocs.insertComponent.tabs",
          "group": "components@9"
        },
        {
          "command": "fumadocs.insertComponent.type-table",
          "group": "components@10"
        },
        {
          "command": "fumadocs.insertComponent.codeblock",
          "group": "components@11"
        },
        {
          "command": "fumadocs.insertComponent.table",
          "group": "components@12"
        }
      ],
      "commandPalette": [
        {
          "command": "fumadocs.insertComponent.accordions",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.banner",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.callout",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.cards",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.code-block-tabs",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.codeblock",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.table",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.files",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.inline-toc",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.steps",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.tabs",
          "when": "false"
        },
        {
          "command": "fumadocs.insertComponent.type-table",
          "when": "false"
        },
        {
          "command": "fumadocs.meta.addPages",
          "when": "false"
        },
        {
          "command": "fumadocs.meta.addRest",
          "when": "false"
        },
        {
          "command": "fumadocs.meta.removeRefs",
          "when": "false"
        },
        {
          "command": "fumadocs.editImage",
          "when": "false"
        }
      ],
      "webview/title": [
        {
          "command": "fumadocs.openInBrowser",
          "when": "webviewPanel == fumadocs.preview",
          "group": "navigation@0"
        },
        {
          "command": "fumadocs.refreshPreview",
          "when": "webviewPanel == fumadocs.preview",
          "group": "navigation@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "fumadocs.openPreview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus && (editorLangId == mdx || editorLangId == markdown || resourceExtname == .md || resourceExtname == .mdx)"
      }
    ],
    "configuration": {
      "title": "Fumadocs Preview",
      "properties": {
        "fumadocs.contentDirNames": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "content"
          ],
          "description": "Directory names treated as a Fumadocs content root when resolving the nearest root of the file being previewed."
        },
        "fumadocs.previewPort": {
          "type": "number",
          "default": 6969,
          "minimum": 1,
          "maximum": 65535,
          "description": "Preferred port for the bundled Fumadocs preview server. If the port is already in use by another process, you'll be asked whether to stop that process or fall back to a free port."
        },
        "fumadocs.autoIncludePages": {
          "type": "boolean",
          "default": true,
          "description": "When a new page is created in a folder whose meta.json has an explicit \"pages\" list (without a \"...\" rest item), automatically add the new page so it doesn't silently disappear from the sidebar."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.2"
  }
}